APP_NAME="Algeciras CF"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Madrid
APP_URL=https://nuevo.algecirasclubdefutbol.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

CLUB_NAME="Algeciras Club de Fútbol"
CLUB_HASHTAG="#CrecemosContigo"
CLUB_SEASON=2026-27

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mariadb
DB_HOST=mariadb-algeciras
DB_PORT=3306
DB_DATABASE=algeciras_cf
DB_USERNAME=algeciras_cf
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=algeciras

REDIS_CLIENT=phpredis
REDIS_HOST=redis-algeciras
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.ionos.es
MAIL_PORT=587
MAIL_USERNAME=info@algecirasclubdefutbol.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@algecirasclubdefutbol.com"
MAIL_FROM_NAME="Algeciras CF"

# Stripe (fase 2 — añadir cuando el club nos dé las claves)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Redsys (fase 3 — cuando el club firme TPV con su banco)
REDSYS_MERCHANT_CODE=
REDSYS_TERMINAL=
REDSYS_SECRET_KEY=
REDSYS_ENVIRONMENT=test

VITE_APP_NAME="${APP_NAME}"
